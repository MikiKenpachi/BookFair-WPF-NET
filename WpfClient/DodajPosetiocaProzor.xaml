<Window x:Class="WpfClient.DodajPosetiocaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="Dodaj Posetioca" Height="450" Width="350"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/bookshelf.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Content="Ime" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtIme" Grid.Row="0" Grid.Column="1" Margin="5" />

        <Label Content="Prezime" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrezime" Grid.Row="1" Grid.Column="1" Margin="5" />

        <Label Content="Datum rođenja" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDatum" Grid.Row="2" Grid.Column="1" Margin="5" />

        <Label Content="Kontakt telefon" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTelefon" Grid.Row="3" Grid.Column="1" Margin="5" />

        <Label Content="Email" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="1" Margin="5" />

        <Label Content="Status" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbStatus" Grid.Row="5" Grid.Column="1" Margin="5">
            <ComboBoxItem Content="Redovan" IsSelected="True"/>
            <ComboBoxItem Content="V.I.P."/>
        </ComboBox>

        <Label Content="Ulica" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUlica" Grid.Row="6" Grid.Column="1" Margin="5" />

        <Label Content="Broj" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBroj" Grid.Row="7" Grid.Column="1" Margin="5" />

        <Label Content="Grad" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtGrad" Grid.Row="8" Grid.Column="1" Margin="5" />

        <Label Content="Država" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDrzava" Grid.Row="9" Grid.Column="1" Margin="5" />

        <StackPanel Orientation="Horizontal" Grid.Row="10" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Odustani" Width="80" Margin="5" Click="BtnOdustani_Click" IsCancel="True"/>
            <Button Content="Potvrdi" Width="80" Margin="5" Background="CornflowerBlue" Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>
