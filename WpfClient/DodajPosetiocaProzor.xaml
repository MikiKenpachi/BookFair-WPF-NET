<Window x:Class="WpfClient.DodajPosetiocaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleDodajPosetioca}" Height="530" Width="420"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/bookshelf.ico">

    <Window.Resources>
        <ControlTemplate x:Key="CrveniOkvir">
            <Border BorderBrush="Red" BorderThickness="0.5">
                <AdornedElementPlaceholder/>
            </Border>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource CrveniOkvir}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Red"/>
                    <Setter Property="BorderThickness" Value="0.1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="{DynamicResource lblIme}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtIme" Grid.Row="0" Grid.Column="1" Margin="5"
                 Text="{Binding Ime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblPrezime}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrezime" Grid.Row="1" Grid.Column="1" Margin="5"
                 Text="{Binding Prezime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblDatumRodjenja}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDatum" Grid.Row="2" Grid.Column="1" Margin="5" SelectedDate="{Binding DatumRodjenja, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
            SelectedDateChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblTelefon}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTelefon" Grid.Row="3" Grid.Column="1" Margin="5"
                 Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblEmail}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="1" Margin="5"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblGodinaClanstva}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtGodinaClanstva" Grid.Row="5" Grid.Column="1" Margin="5"
                 Text="{Binding GodinaClanstva, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblStatus}" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbStatus" Grid.Row="6" Grid.Column="1" Margin="5">
            <ComboBoxItem IsSelected="True">
                <TextBlock Text="{DynamicResource statusRedovan}"/>
            </ComboBoxItem>
            <ComboBoxItem>
                <TextBlock Text="{DynamicResource statusVIP}"/>
            </ComboBoxItem>
        </ComboBox>

        <Label Content="{DynamicResource lblUlica}" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUlica" Grid.Row="7" Grid.Column="1" Margin="5"
                 Text="{Binding Ulica, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblBroj}" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBroj" Grid.Row="8" Grid.Column="1" Margin="5"
                 Text="{Binding Broj, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblGrad}" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtGrad" Grid.Row="9" Grid.Column="1" Margin="5"
                 Text="{Binding Grad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblDrzava}" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDrzava" Grid.Row="10" Grid.Column="1" Margin="5"
                 Text="{Binding Drzava, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <StackPanel Orientation="Horizontal" Grid.Row="11" Grid.ColumnSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
            <Button Content="{DynamicResource btnOdustani}" Width="80" Margin="5"
                    Click="BtnOdustani_Click" IsCancel="True"/>
            <Button x:Name="btnPotvrdi" Content="{DynamicResource btnPotvrdi}" Width="80" Margin="5"
                    Background="CornflowerBlue" Click="BtnPotvrdi_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>