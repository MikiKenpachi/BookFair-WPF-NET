<Window x:Class="WpfClient.DodajAutoraProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleDodajAutora}" Height="530" Width="420"
        WindowStartupLocation="CenterOwner"
        Icon="Resources/bookshelf.ico">

    <Window.Resources>
        <ControlTemplate x:Key="GreskaTemplate">
            <Border BorderBrush="Red" BorderThickness="1.5">
                <AdornedElementPlaceholder x:Name="OriginalnaKontrola"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" 
                        Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="{DynamicResource lblIme}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtIme" Grid.Row="0" Grid.Column="1" Margin="5"
                 Text="{Binding Ime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblPrezime}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtPrezime" Grid.Row="1" Grid.Column="1" Margin="5"
                 Text="{Binding Prezime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblDatumRodjenja}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpDatum" Grid.Row="2" Grid.Column="1" Margin="5"
                    SelectedDate="{Binding DatumRodjenja, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                    SelectedDateChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblTelefon}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtTelefon" Grid.Row="3" Grid.Column="1" Margin="5"
                 Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblEmail}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtEmail" Grid.Row="4" Grid.Column="1" Margin="5"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblUlica}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtUlica" Grid.Row="5" Grid.Column="1" Margin="5"
                 Text="{Binding Ulica, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblBroj}" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBroj" Grid.Row="6" Grid.Column="1" Margin="5"
                 Text="{Binding Broj, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblGrad}" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtGrad" Grid.Row="7" Grid.Column="1" Margin="5"
                 Text="{Binding Grad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblDrzava}" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDrzava" Grid.Row="8" Grid.Column="1" Margin="5"
                 Text="{Binding Drzava, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblIskustvo}" Grid.Row="9" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtIskustvo" Grid.Row="9" Grid.Column="1" Margin="5"
                 Text="{Binding GodineIskustva, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <Label Content="{DynamicResource lblBrojLK}" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBrojLk" Grid.Row="10" Grid.Column="1" Margin="5"
                 Text="{Binding BrojLk, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                 TextChanged="TxtPolje_Changed"/>

        <StackPanel Orientation="Horizontal" Grid.Row="11" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,15,0,0">
            <Button Content="{DynamicResource btnOdustani}" Width="80" Margin="5" Click="BtnOdustani_Click" IsCancel="True"/>
            <Button x:Name="btnPotvrdi" Content="{DynamicResource btnPotvrdi}" Width="80" Margin="5"
                    Background="CornflowerBlue" Click="BtnPotvrdi_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>