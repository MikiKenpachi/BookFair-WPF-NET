<Window x:Class="WpfClient.DodajNaListuZeljaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleDodajNaListuZelja}"
        Width="450" Height="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="Resources/bookshelf.ico">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" x:Name="listKnjige"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource colISBN}"  Binding="{Binding ISBN}"   Width="80"/>
                <DataGridTextColumn Header="{DynamicResource colNaziv}" Binding="{Binding Naziv}"  Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colZanr}"  Binding="{Binding Zanr}"   Width="90"/>
                <DataGridTextColumn Header="{DynamicResource colCena}"  Binding="{Binding Cena}"   Width="65"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource btnOdustani}" Width="80" Margin="0,0,8,0"
                    Click="BtnOdustani_Click"/>
            <Button Content="{DynamicResource btnDodajNaListu}"    Width="80"
                    Click="BtnDodaj_Click"/>
        </StackPanel>
    </Grid>
</Window>