<Window x:Class="WpfClient.AutoriIzdavacaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleAutoriIzdavaca}" Height="450" Width="800"
        WindowStartupLocation="CenterOwner" FontFamily="Kristen ITC"
        Icon="/Resources/bookshelf.ico">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtNaslov" Text="{DynamicResource txtSelectedPublisher}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox x:Name="txtPretraga" Width="150" Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                <Button x:Name="btnPretrazi" 
                        Content="🔍" 
                        FontSize="16"
                        Width="40" Height="25" 
                        Click="BtnPretrazi_Click"
                        ToolTip="{DynamicResource tipPretraziAutore}"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="dgAutori" Grid.Row="1" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="#FF95B5EB" RowHeight="28" FontWeight="Bold">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource colIme}" Binding="{Binding Ime}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colPrezime}" Binding="{Binding Prezime}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colDatumRodjenja}" 
                                    Binding="{Binding Datum_rodjenja, StringFormat=\{0:dd.MM.yyyy\}}" 
                                    Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colAdresa}" Width="2*">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1}, {2}, {3}">
                            <Binding Path="Adresa.Ulica" />
                            <Binding Path="Adresa.Broj" />
                            <Binding Path="Adresa.Grad" />
                            <Binding Path="Adresa.Drzava" />
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{DynamicResource colTelefon}" Binding="{Binding Telefon}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colEmail}" Binding="{Binding Email}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="{DynamicResource btnZatvori}" Grid.Row="2" Width="100" Height="30" 
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="BtnZatvori_Click" VerticalAlignment="Top"/>
    </Grid>
</Window>