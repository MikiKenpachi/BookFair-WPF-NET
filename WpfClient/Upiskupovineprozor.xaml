<Window x:Class="WpfClient.UpisKupovineProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleUpisKupovine}"
        Width="380" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/Resources/bookshelf.ico" >

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="ISBN *" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="txtISBN"
                   IsReadOnly="True" Background="#f0f0f0" Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource colNaziv}" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="1" Grid.Column="1" x:Name="txtNaziv"
                   IsReadOnly="True" Background="#f0f0f0" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource lblOcena}" VerticalAlignment="Center" Margin="0,5"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="txtOcena"
                   Margin="0,5" MaxLength="1"
                   TextChanged="txtOcena_TextChanged"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource lblDatumKupovine}" VerticalAlignment="Center" Margin="0,5"/>
        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="dpDatumKupovine" Margin="0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource lblKomentar}" VerticalAlignment="Top" Margin="0,8,0,0"/>
        <TextBox   Grid.Row="4" Grid.Column="1" Grid.RowSpan="2"
                   x:Name="txtKomentar"
                   Height="60" TextWrapping="Wrap"
                   AcceptsReturn="True" Margin="0,5"/>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{DynamicResource btnOdustani}" Width="80" Margin="0,0,8,0"
                    Click="BtnOdustani_Click"/>
            <Button x:Name="btnPotvrdi" Content="{DynamicResource btnPotvrdi}" Width="80"
                    IsEnabled="False"
                    Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>
