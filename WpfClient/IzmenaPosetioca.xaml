<Window x:Class="WpfClient.IzmenaPosetioca"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Izmena posetioca" Height="620" Width="500" 
        WindowStartupLocation="CenterOwner"
        FontFamily="Kristen ITC" ResizeMode="NoResize"
        Icon="Resources/bookshelf.ico">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Informacije">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Broj članske karte *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtBrClanske" Grid.Row="0" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center" IsReadOnly="True" Background="#F0F0F0"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ime *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtIme" Grid.Row="1" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Prezime *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtPrezime" Grid.Row="2" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Datum rođenja *" VerticalAlignment="Center" Margin="0,5"/>
                    <DatePicker x:Name="dpDatumRodjenja" Grid.Row="3" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Kontakt telefon *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtTelefon" Grid.Row="4" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Email *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Status *" VerticalAlignment="Center" Margin="0,5"/>
                    <ComboBox x:Name="cmbStatus" Grid.Row="6" Grid.Column="1" Margin="10,5,0,5" Height="25">
                        <ComboBoxItem Content="Redovan"/>
                        <ComboBoxItem Content="VIP"/>
                    </ComboBox>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Ulica *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtUlica" Grid.Row="7" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Broj *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtBroj" Grid.Row="8" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Grad *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtGrad" Grid.Row="9" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Država *" VerticalAlignment="Center" Margin="0,5"/>
                    <TextBox x:Name="txtDrzava" Grid.Row="10" Grid.Column="1" Margin="10,5,0,5" Height="25" VerticalContentAlignment="Center"/>
                </Grid>
            </TabItem>

            <TabItem Header="Kupljene">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Poništi kupovinu"
                            HorizontalAlignment="Left" Margin="0,0,0,8"
                            Click="BtnPonistiKupovinu_Click"/>

                    <DataGrid Grid.Row="1" x:Name="dgKupljene"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ISBN"   Binding="{Binding Knjiga.ISBN}"           Width="80"/>
                            <DataGridTextColumn Header="Naziv"  Binding="{Binding Knjiga.Naziv}"          Width="*"/>
                            <DataGridTextColumn Header="Datum"  Binding="{Binding Datum_kupovine, StringFormat=dd.MM.yyyy.}" Width="90"/>
                            <DataGridTextColumn Header="Ocena"  Binding="{Binding Ocena}"                 Width="55"/>
                            <DataGridTextColumn Header="Cena"   Binding="{Binding Knjiga.Cena}"           Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock x:Name="lblProsecnaOcena" Text="Prosečna ocena: —"
                                   Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblUkupnoPotroseno" Text="Potrošeno: — RSD"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Želje">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Dodaj"    Width="70" Margin="0,0,6,0"
                                Click="BtnDodajNaListuZelja_Click"/>
                        <Button Content="Obriši"   Width="70" Margin="0,0,6,0"
                                Click="BtnUkloniSaListeZelja_Click"/>
                        <Button Content="Kupovina" Width="80"
                                Click="BtnUpisKupovine_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="dgZelje"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ISBN"  Binding="{Binding ISBN}"   Width="80"/>
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}"  Width="*"/>
                            <DataGridTextColumn Header="Žanr"  Binding="{Binding Zanr}"   Width="90"/>
                            <DataGridTextColumn Header="Cena"  Binding="{Binding Cena}"   Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,5">
            <Button Content="Odustani" Width="100" Height="30" Margin="5,0" Click="BtnOdustani_Click"/>
            <Button Content="Potvrdi" Width="100" Height="30" Background="#95B5EB" FontWeight="Bold" Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>