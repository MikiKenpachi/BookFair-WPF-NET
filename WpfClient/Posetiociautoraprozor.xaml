<Window x:Class="WpfClient.Posetiociautoraprozor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titlePosetiociAutora}" Height="450" Width="850"
        WindowStartupLocation="CenterOwner" FontFamily="Kristen ITC"
        Icon="/Resources/bookshelf.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov + pretraga -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtNaslov"
                       Text="{DynamicResource lblPosetiociAutoraNaslov}"
                       FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox x:Name="txtPretraga" Width="150" Height="25"
                         VerticalContentAlignment="Center" Margin="5,0"/>
                <Button x:Name="btnPretrazi"
                        Content="🔍" FontSize="16"
                        Width="40" Height="25"
                        Click="BtnPretrazi_Click"
                        ToolTip="{DynamicResource tipPretraziPosetioce}"/>
            </StackPanel>
        </DockPanel>

        <!-- Tabela posjetilaca -->
        <DataGrid x:Name="dgPosetioci" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF95B5EB" RowHeight="28" FontWeight="Bold">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource colClanskaKarta}"
                                    Binding="{Binding BrClanskeKarte}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colIme}"
                                    Binding="{Binding Ime}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colPrezime}"
                                    Binding="{Binding Prezime}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colStatus}"
                                    Binding="{Binding Status}" Width="0.6*"/>
                <DataGridTextColumn Header="{DynamicResource colAdresa}" Width="2*">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="{}{0} {1}, {2}, {3}">
                            <Binding Path="Adresa.Ulica"/>
                            <Binding Path="Adresa.Broj"/>
                            <Binding Path="Adresa.Grad"/>
                            <Binding Path="Adresa.Drzava"/>
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Zatvori dugme -->
        <Button Content="{DynamicResource btnZatvori}" Grid.Row="2"
                Width="100" Height="30"
                HorizontalAlignment="Right" Margin="0,10,0,0"
                Click="BtnZatvori_Click"/>
    </Grid>
</Window>