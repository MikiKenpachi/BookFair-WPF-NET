<Window x:Class="WpfClient.DodajKnjiguProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="DodajKnjiguProzor" Height="350" Width="350"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Content="ISBN" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtISBN" Grid.Row="0" Grid.Column="1" Margin="5" />

        <Label Content="Naziv" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNaziv" Grid.Row="1" Grid.Column="1" Margin="5" />

        <Label Content="Godina izdanja" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="dpGI" Grid.Row="2" Grid.Column="1" Margin="5" />

        <Label Content="Cena" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtCena" Grid.Row="3" Grid.Column="1" Margin="5" />

        <Label Content="Broj strana" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtBS" Grid.Row="4" Grid.Column="1" Margin="5" />

        <Label Content="Status" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbStatus" Grid.Row="5" Grid.Column="1" Margin="5">
            <ComboBoxItem Content="Romantika" Tag="Roman" IsSelected="True"/>
            <ComboBoxItem Content="Naučna fantastika" Tag="Naucna_Fantastika"/>
            <ComboBoxItem Content="Triler" Tag="Triler"/>
            <ComboBoxItem Content="Horor" Tag="Horor"/>
            <ComboBoxItem Content="Biografija" Tag="Biografija"/>
            <ComboBoxItem Content="Fantazija" Tag="Fantastika"/>
            <ComboBoxItem Content="Poezija" Tag="Poezija"/>
            <ComboBoxItem Content="Drama" Tag="Drama"/>
            <ComboBoxItem Content="Kriminalistika" Tag="Kriminalistika"/>
            <ComboBoxItem Content="Klasika" Tag="Klasika"/>
            <ComboBoxItem Content="Psihologija" Tag="Psihologija"/>
            <ComboBoxItem Content="Dečija literatura" Tag="Decija_Literatura"/>
            <ComboBoxItem Content="Stručna literatura" Tag="Strucna_Literatura"/>
            <ComboBoxItem Content="Enciklopedija" Tag="Enciklopedija"/>
        </ComboBox>

        <Label Content="Autor" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbAutor" Grid.Row="6" Grid.Column="1" Margin="5" 
          DisplayMemberPath="ImePrezime" />

        <Label Content="Izdavač" Grid.Row="7" Grid.Column="0" VerticalAlignment="Center"/>
        <ComboBox x:Name="cbIzdavac" Grid.Row="7" Grid.Column="1" Margin="5" 
          DisplayMemberPath="Naziv" />



        <StackPanel Orientation="Horizontal" Grid.Row="10" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Odustani" Width="80" Margin="5" Click="BtnOdustani_Click" IsCancel="True"/>
            <Button Content="Potvrdi" Width="80" Margin="5" Background="CornflowerBlue" Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>
