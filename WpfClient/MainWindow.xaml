<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="WpfClient.MainWindow"
        Title="Sajam knjiga"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        Loaded="Window_Loaded" av:DesignHeight="378.3" av:DesignWidth="574.75" FontFamily="Kristen ITC">

    <DockPanel>

        <!-- MENU BAR -->
        <Menu DockPanel.Dock="Top" FontFamily="Kristen ITC" Background="White">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Click="BtnDodaj_Click" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Save" Click="BtnSave_Click" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="_Open">
                    <MenuItem Header="_Posetioci" Click="MenuPosetioci_Click" />
                    <MenuItem Header="_Knjige" Click="MenuKnjige_Click" />
                    <MenuItem Header="_Autori" Click="MenuAutori_Click" />
                    <Separator />
                    <MenuItem Header="_Izdavači" Click="MenuIzdavaci_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="_Close" Click="MenuClose_Click" InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Edit" Click="BtnIzmeni_Click" />
                <MenuItem Header="_Delete" Click="BtnObrisi_Click" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" 
             Height="40" ToolBarTray.IsLocked="True">

                <ToolBar.Template>
                    <ControlTemplate TargetType="ToolBar">
                        <ToolBarPanel IsItemsHost="True" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </ToolBar.Template>

                <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=ToolBarTray}, Path=ActualWidth}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                        <Button Content="+" Width="30" Height="30" Click="BtnDodaj_Click" ToolTip="Dodaj" Margin="2,0"/>
                        <Button Content="✎" Width="30" Height="30" Click="BtnIzmeni_Click" ToolTip="Izmeni" Margin="2,0"/>
                        <Button Content="🗑" Width="30" Height="30" Click="BtnObrisi_Click" ToolTip="Obriši" Margin="2,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBox Width="154" Height="25" VerticalContentAlignment="Center" Margin="5,0" />
                        <Button Content="🔍" Width="30" Height="25"/>
                    </StackPanel>
                </Grid>
            </ToolBar>
        </ToolBarTray>

    
        
        
        
        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom" FontFamily="Kristen ITC">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Sajam knjiga - "/>
                    <TextBlock Text="{Binding ElementName=MainTabControl, Path=SelectedItem.Header}"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="lblTime" />
                    <TextBlock Text="   " />
                    <TextBlock x:Name="lblDate" Margin="0,0,10,0" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- CENTRALNI PANEL -->
        <TabControl x:Name="MainTabControl">

            <!-- TAB 1 -->
            <TabItem Header="Posetioci">
                <Grid Margin="5">
                    <DataGrid x:Name="DataGridPosetioci" 
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          IsReadOnly="True"
          SelectionMode="Single" Background="#FF95B5EB" SelectionChanged="DataGridPosetioci_SelectionChanged" Opacity="0.9" FontWeight="Bold">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Broj članske karte" Binding="{Binding BrClanskeKarte}" Width="*" />
                            <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="*" />
                            <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="*" />
                            <DataGridTextColumn Header="Adresa" Width="3*">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0} {1}, {2}, {3}">
                                        <Binding Path="Adresa.Ulica" />
                                        <Binding Path="Adresa.Broj" />
                                        <Binding Path="Adresa.Grad" />
                                        <Binding Path="Adresa.Drzava" />
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="Status" 
                            Binding="{Binding Status}" 
                            Width="0.5*" />
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>


            <TabItem Header="Autori">
                <Grid Margin="5">
                    <DataGrid  x:Name="dbAutori" ItemsSource="{Binding Autori}" CanUserDeleteRows="False"
IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="*"/>
                            <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="*"/>
                            <DataGridTextColumn Header="Br. lične karte" Binding="{Binding Broj_lk}" Width="*"/>
                            <DataGridTextColumn Header="Datum rođenja" Binding="{Binding Datum_rodjenja, StringFormat=\{0:dd.MM.yyyy\}}" Width="*"/>
                            <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Knjige">
                <Grid Margin="5">
                    <DataGrid x:Name="dbKnjige" ItemsSource="{Binding Knjige}" CanUserDeleteRows="False"
IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="*"/>
                            <DataGridTextColumn Header="Naziv" Binding="{Binding Naziv}" Width="2*"/>
                            <DataGridTextColumn Header="Cena" Binding="{Binding Cena}" Width="*"/>
                            <DataGridTextColumn Header="Godina izdanja" Binding="{Binding Godina_izdanja}" Width="*"/>
                            <DataGridTextColumn Header="Žanr" Binding="{Binding Zanr}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
