<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="WpfClient.MainWindow"
        Title="Sajam knjiga"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Manual"
        Loaded="Window_Loaded" av:DesignHeight="378.3" av:DesignWidth="574.75">

    <DockPanel>

        <!-- MENU BAR -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Exit"/>
            </MenuItem>
            <MenuItem Header="Edit"/>
            <MenuItem Header="Help"/>
        </Menu>

        <!-- TOOLBAR -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="+" Width="30" Height="30" />
                <Button Content="✎" Width="30" Height="30" />
                <Button Content="🗑" Width="30" Height="30" />

                <Separator/>

                <!-- Search desno -->
                <DockPanel Width="200">
                    <TextBox Width="150" Margin="5,0"/>
                    <Button Content="🔍" Width="30"/>
                </DockPanel>
            </ToolBar>
        </ToolBarTray>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Sajam knjiga - Posetioci"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentTime}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- CENTRALNI PANEL -->
        <TabControl>

            <!-- TAB 1 -->
            <TabItem Header="Posetioci">
                <Grid Margin="5">
                    <DataGrid ItemsSource="{Binding Posetioci}" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single">
                        <DataGrid.Columns>
                            <!-- Kolona za broj članske karte -->
                            <DataGridTextColumn Header="Broj članske karte" Binding="{Binding BrClanskeKarte}" Width="2*"/>

                            <!-- Kolona za ime posetioca -->
                            <DataGridTextColumn Header="Ime" Binding="{Binding Ime}" Width="*"/>

                            <!-- Kolona za prezime posetioca -->
                            <DataGridTextColumn Header="Prezime" Binding="{Binding Prezime}" Width="*"/>

                            <!-- Kolona za adresu (dot notation za pristup svojstvu Adresa.Ulica) -->
                            <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa.Ulica}" Width="3*"/>

                            <!-- Kolona za status posetioca (prikazuje enum StatusPosetioca) -->
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.5*"/>

                            <!-- Kolona za prosečnu ocenu (ako postoji) -->
                            <DataGridTextColumn Header="Prosečna ocena" Binding="{Binding ProsecnaOcena}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>


            <!-- TAB 2 -->
            <TabItem Header="Autori">
                <Grid Margin="5">
                    <DataGrid AutoGenerateColumns="True"/>
                </Grid>
            </TabItem>

            <!-- TAB 3 -->
            <TabItem Header="Knjige">
                <Grid Margin="5">
                    <DataGrid AutoGenerateColumns="True"/>
                </Grid>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
