<Window x:Class="WpfClient.IzmenaAutora"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleIzmenaAutora}" Height="650" Width="450" 
        WindowStartupLocation="CenterOwner"
        FontFamily="Kristen ITC" ResizeMode="NoResize"
        Icon="Resources/bookshelf.ico">

    <Window.Resources>
        <ControlTemplate x:Key="GreskaTemplate">
            <Border BorderBrush="Red" BorderThickness="1.5">
                <AdornedElementPlaceholder x:Name="OriginalnaKontrola"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" 
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors).CurrentItem.ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="{DynamicResource tabInformacije}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{DynamicResource lblBrojLK}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtBrojLK" Grid.Row="0" Grid.Column="1" Margin="10,5,0,5" Height="25" IsReadOnly="True" Background="#F0F0F0"
                                 Text="{Binding BrojLk, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                        <TextBlock Grid.Row="1" Text="{DynamicResource lblIme}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtIme" Grid.Row="1" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Ime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="2" Text="{DynamicResource lblPrezime}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtPrezime" Grid.Row="2" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Prezime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="3" Text="{DynamicResource lblDatumRodjenja}" VerticalAlignment="Center" Margin="0,5"/>
                        <DatePicker x:Name="dpDatumRodjenja" Grid.Row="3" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                    SelectedDate="{Binding DatumRodjenja, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                    SelectedDateChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="4" Text="{DynamicResource lblTelefon}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtTelefon" Grid.Row="4" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Telefon, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="5" Text="{DynamicResource lblEmail}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="6" Text="{DynamicResource lblIskustvo}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtIskustvo" Grid.Row="6" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding GodineIskustva, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="7" Text="{DynamicResource lblUlica}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtUlica" Grid.Row="7" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Ulica, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="8" Text="{DynamicResource lblBroj}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtBroj" Grid.Row="8" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Broj, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="9" Text="{DynamicResource lblGrad}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtGrad" Grid.Row="9" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Grad, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>

                        <TextBlock Grid.Row="10" Text="{DynamicResource lblDrzava}" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtDrzava" Grid.Row="10" Grid.Column="1" Margin="10,5,0,5" Height="25"
                                 Text="{Binding Drzava, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                 TextChanged="Polje_Changed"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{DynamicResource tabKnjige}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{DynamicResource btnDodajKnjiguAutoru}"
                                Width="110" Height="30" Margin="0,0,8,0"
                                Click="BtnDodajKnjigu_Click"
                                ToolTip="{DynamicResource tipDodajKnjiguAutoru}"/>
                        <Button Content="{DynamicResource btnUkloniKnjiguAutoru}"
                                Width="110" Height="30"
                                Click="BtnUkloniKnjigu_Click"
                                ToolTip="{DynamicResource tipUkloniKnjiguAutoru}"/>
                    </StackPanel>

                    <DataGrid x:Name="dgKnjige"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource colISBN}" Binding="{Binding ISBN}" Width="80"/>
                            <DataGridTextColumn Header="{DynamicResource colNaziv}" Binding="{Binding Naziv}" Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource colGodinaIzdanja}" Binding="{Binding Godina_izdanja}" Width="110"/>
                            <DataGridTextColumn Header="{DynamicResource colZanr}" Binding="{Binding Zanr}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,5">
            <Button Content="{DynamicResource btnOdustani}" Width="100" Height="30" Margin="5,0" Click="BtnOdustani_Click"/>
            <Button x:Name="btnPotvrdi" Content="{DynamicResource btnPotvrdi}" Width="100" Height="30" 
                    Background="#95B5EB" FontWeight="Bold" Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>