<Window x:Class="WpfClient.IzmenaAutora"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Izmena autora" Height="650" Width="450" 
        WindowStartupLocation="CenterOwner"
        FontFamily="Kristen ITC" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Informacije">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Broj lične karte *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtBrojLK" Grid.Row="0" Grid.Column="1" Margin="10,5,0,5" Height="25" IsReadOnly="True" Background="#F0F0F0"/>

                        <TextBlock Grid.Row="1" Text="Ime *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtIme" Grid.Row="1" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="2" Text="Prezime *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtPrezime" Grid.Row="2" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="3" Text="Datum rođenja *" VerticalAlignment="Center" Margin="0,5"/>
                        <DatePicker x:Name="dpDatumRodjenja" Grid.Row="3" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="4" Text="Kontakt telefon *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtTelefon" Grid.Row="4" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="5" Text="Email *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtEmail" Grid.Row="5" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="6" Text="Iskustvo (godine) *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtIskustvo" Grid.Row="6" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="7" Text="Ulica *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtUlica" Grid.Row="7" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="8" Text="Broj *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtBroj" Grid.Row="8" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="9" Text="Grad *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtGrad" Grid.Row="9" Grid.Column="1" Margin="10,5,0,5" Height="25"/>

                        <TextBlock Grid.Row="10" Text="Država *" VerticalAlignment="Center" Margin="0,5"/>
                        <TextBox x:Name="txtDrzava" Grid.Row="10" Grid.Column="1" Margin="10,5,0,5" Height="25"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,5">
            <Button Content="Odustani" Width="100" Height="30" Margin="5,0" Click="BtnOdustani_Click"/>
            <Button Content="Potvrdi" Width="100" Height="30" Background="#95B5EB" FontWeight="Bold" Click="BtnPotvrdi_Click"/>
        </StackPanel>
    </Grid>
</Window>
