<Window x:Class="WpfClient.DodajIzdavacaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalji Izdavača" Height="350" Width="400"
        WindowStartupLocation="CenterOwner" FontFamily="Kristen ITC">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Šifra izdavača:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtSifra" Height="25" Margin="0,0,0,15"/>

            <TextBlock Text="Naziv izdavača:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNaziv" Height="25" Margin="0,0,0,15"/>

            <TextBlock Text="Šef (Autor):" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbSefovi" Height="25" Margin="0,0,0,20" 
                      DisplayMemberPath="ImePrezime"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Potvrdi" Width="80" Height="30" Margin="5" Click="BtnPotvrdi_Click"/>
                <Button Content="Odustani" Width="80" Height="30" Margin="5" Click="BtnOdustani_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
