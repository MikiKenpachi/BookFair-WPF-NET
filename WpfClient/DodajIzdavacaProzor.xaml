<Window x:Class="WpfClient.DodajIzdavacaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleDetaljiIzdavaca}" Height="380" Width="400"
        WindowStartupLocation="CenterOwner" FontFamily="Kristen ITC"
        Icon="Resources/bookshelf.ico">

    <Window.Resources>
        <ControlTemplate x:Key="GreskaTemplate">
            <StackPanel>
                <Border BorderBrush="Red" BorderThickness="2">
                    <AdornedElementPlaceholder x:Name="OriginalnaKontrola"/>
                </Border>
                <TextBlock Text="{Binding [0].ErrorContent}" 
                           Foreground="Red" 
                           FontSize="11" 
                           FontWeight="Bold"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </ControlTemplate>

        <Style TargetType="TextBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource GreskaTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource lblSifraIzdavaca}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtSifra" 
                     Height="25" Margin="0,0,0,15"
                     Text="{Binding Sifra, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Text="{DynamicResource lblNazivIzdavaca}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNaziv" 
                     Height="25" Margin="0,0,0,15"
                     Text="{Binding Naziv, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Text="{DynamicResource lblSefAutor}" Margin="0,0,0,5"/>
            <ComboBox x:Name="cbSefovi" 
                      Height="25" Margin="0,0,0,20" 
                      DisplayMemberPath="ImePrezime"
                      SelectedItem="{Binding SefIzdavaca, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{DynamicResource btnPotvrdi}" Width="90" Height="30" Margin="5" Click="BtnPotvrdi_Click" Background="#FFD1E1FB" FontWeight="Bold"/>
                <Button Content="{DynamicResource btnOdustani}" Width="90" Height="30" Margin="5" Click="BtnOdustani_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
