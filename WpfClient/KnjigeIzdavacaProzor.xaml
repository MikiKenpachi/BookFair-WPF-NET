<Window x:Class="WpfClient.KnjigeIzdavacaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Knjige izdavača" Height="500" Width="750"
        WindowStartupLocation="CenterOwner"
        FontFamily="Kristen ITC"
        Icon="/Resources/bookshelf.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <TextBlock x:Name="txtNaslov"
                   Grid.Row="0"
                   Text="{DynamicResource titleKnjigeIzdavaca}"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>
        
        <!-- Pretraga -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtPretraga"
                     Width="300"
                     Height="28"
                     VerticalContentAlignment="Center"
                     Padding="4,0"
                     Margin="0,0,8,0"/>
            <Button Width="35"
                Height="28"
                Click="BtnPretrazi_Click"
                ToolTip="{DynamicResource tipPretraziKnjige}">
                <TextBlock Text="🔍" FontSize="14"/> 
            </Button>
        </StackPanel>

        <!-- DataGrid knjiga -->
        <DataGrid x:Name="dgKnjige"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  CanUserAddRows="False"
                  AlternatingRowBackground="#F0F0F0"
                  BorderBrush="#DDDDDD"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ISBN"         Binding="{Binding ISBN}"           Width="100"/>
                <DataGridTextColumn Header="Naziv"        Binding="{Binding Naziv}"          Width="*"/>
                <DataGridTextColumn Header="Žanr"         Binding="{Binding Zanr}"           Width="110"/>
                <DataGridTextColumn Header="Godina"       Binding="{Binding Godina_izdanja}" Width="70"/>
                <DataGridTextColumn Header="Cena (RSD)"   Binding="{Binding Cena}"           Width="90"/>
                <DataGridTextColumn Header="Broj strana"  Binding="{Binding Broj_strana}"    Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Dugme Zatvori -->
        <Button Grid.Row="3"
                Content="Zatvori"
                Width="90"
                Height="35"
                HorizontalAlignment="Right"
                Click="BtnZatvori_Click"/>
    </Grid>
</Window>