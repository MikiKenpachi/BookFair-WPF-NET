<Window x:Class="WpfClient.KnjigeIzdavacaProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource titleKnjigeIzdavaca}" Height="450" Width="800"
        WindowStartupLocation="CenterOwner" FontFamily="Kristen ITC"
        Icon="/Resources/bookshelf.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="txtNaslov" Text="{DynamicResource txtSelectedPublisher}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBox x:Name="txtPretraga" Width="150" Height="25" VerticalContentAlignment="Center" Margin="5,0"/>
                <Button x:Name="btnPretrazi"
                        Content="🔍"
                        FontSize="16"
                        Width="40" Height="25"
                        Click="BtnPretrazi_Click"
                        ToolTip="{DynamicResource tipPretraziKnjige}"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="dgKnjige" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF95B5EB" RowHeight="28" FontWeight="Bold">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource colISBN}" Binding="{Binding ISBN}" Width="100"/>
                <DataGridTextColumn Header="{DynamicResource colNaziv}" Binding="{Binding Naziv}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colZanr}" Binding="{Binding Zanr}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource colGodina}" Binding="{Binding Godina_izdanja}" Width="80"/>
                <DataGridTextColumn Header="{DynamicResource colCena}" Binding="{Binding Cena}" Width="90"/>
                <DataGridTextColumn Header="{DynamicResource colBrojStrana}" Binding="{Binding Broj_strana}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="{DynamicResource btnZatvori}" Grid.Row="2" Width="100" Height="30"
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="BtnZatvori_Click" VerticalAlignment="Top"/>
    </Grid>
</Window>