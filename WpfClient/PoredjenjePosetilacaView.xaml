<Window x:Class="WpfClient.PoredjenjePosetilacaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfClient"
        mc:Ignorable="d"
        Title="{DynamicResource titlePoredjenjePosetilaca}" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        Icon="/Resources/bookshelf.ico">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource lblNaslovPoredjenja}"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="{DynamicResource lblKnjiga1}" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbKnjiga1"
                      Width="200"
                      Margin="10,0,20,0"
                      DisplayMemberPath="Naziv"/>

            <TextBlock Text="{DynamicResource lblKnjiga2}" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbKnjiga2"
                      Width="200"
                      Margin="10,0,20,0" 
                      DisplayMemberPath="Naziv"/>

            <Button Content="{DynamicResource btnPrikazi}"
                    Width="100"
                    Click="Prikazi_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{DynamicResource lblObaNaZelji}"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="SearchLevoTextBox"
                             Width="200"
                             Margin="0,0,10,0"/>
                    <Button Content="{DynamicResource btnPretrazi}"
                            Width="80"
                            Click="SearchLevo_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgZeljeObe"
                          AutoGenerateColumns="False"
                          Height="400"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource colClanskaKarta}" Binding="{Binding BrClanskeKarte}" SortMemberPath="ClanskaKartaBroj" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colIme}" Binding="{Binding Ime}" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colPrezime}" Binding="{Binding Prezime}" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colStatus}" Binding="{Binding Status}" Width="0.7*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource lblKupiliSamoPrvu}"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="SearchDesnoTextBox"
                             Width="200"
                             Margin="0,0,10,0"/>
                    <Button Content="{DynamicResource btnPretrazi}"
                            Width="80"
                            Click="SearchDesno_Click"/>
                </StackPanel>

                <DataGrid x:Name="dgKupljenaPrva"
                          AutoGenerateColumns="False"
                          Height="400"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource colClanskaKarta}" Binding="{Binding BrClanskeKarte}" SortMemberPath="ClanskaKartaBroj" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colIme}" Binding="{Binding Ime}" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colPrezime}" Binding="{Binding Prezime}" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource colStatus}" Binding="{Binding Status}" Width="0.7*" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        <Button Grid.Row="3"
                Content="{DynamicResource btnZatvori}"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="Zatvori_Click"/>
    </Grid>
</Window>